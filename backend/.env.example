# Application Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
PASSWORD_RESET_URL=http://localhost:3001/reset-password

# Logging and Monitoring Configuration
LOG_LEVEL=debug
LOG_FORMAT=simple
LOG_SLOW_REQUEST_THRESHOLD=500
LOG_SKIP_PATHS=/health
LOG_MAX_FILES=7d
LOG_MAX_SIZE=10m
METRICS_ENABLED=true
TRACING_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Authentication Configuration
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Security Configuration
SECURITY_ENCRYPTION_KEY=CHANGE_ME
SECURITY_CSRF_ENABLED=false
SECURITY_SESSION_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS

# Rate Limiting Configuration
